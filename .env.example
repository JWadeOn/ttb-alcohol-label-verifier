# Required for primary extraction (gpt-4o-mini vision). Never commit real keys.
OPENAI_API_KEY=

# Optional: after changing this file during `next dev`, if the browser shows "React Client Manifest"
# errors, stop all dev servers, run `npm run dev:clean`, and avoid two `next dev` on the same port.

# Optional: block all OpenAI completions while keeping OPENAI_API_KEY set (503 OPENAI_DISABLED; saves credits).
# OPENAI_DISABLED=true

# Optional (local / test only): return HTTP 200 with a typed stub success body — reach Results UI without OpenAI.
# Ignored when NODE_ENV=production. Remove for real extractions.
# VERIFY_DEV_STUB=true

# Optional: override primary-extraction failover timeouts. When unset, extraction has no forced
# soft/hard timeout. Set these for faster failover to unavailable during local experiments.
# VERIFY_EXTRACT_SOFT_TIMEOUT_MS=3000
# VERIFY_EXTRACT_HARD_TIMEOUT_MS=3500

# Optional: LLM latency/cost tuning for OpenAI vision extraction.
# OPENAI_VISION_DETAIL=low     # low | auto | high (default low for faster responses)
# OPENAI_MAX_OUTPUT_TOKENS=500 # integer 200..4096 (default 500)

# Optional: extraction routing mode.
# VERIFY_EXTRACTION_MODE=hybrid # hybrid | llm_only | ocr_only (default hybrid)
# VERIFY_OCR_MIN_CRITICAL_FIELDS_PRESENT=3  # 1..5, for hybrid escalation to LLM
# VERIFY_OCR_MIN_MEAN_CONFIDENCE=0.58       # 0..1, for hybrid escalation to LLM
# VERIFY_OCR_MIN_REQUIRED_FIELD_CONFIDENCE=0.52 # 0..1 for required fields (class/alcohol/net)
