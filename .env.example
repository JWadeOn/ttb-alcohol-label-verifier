# Required for primary extraction (gpt-4o-mini vision). Never commit real keys.
OPENAI_API_KEY=

# Optional: after changing this file during `next dev`, if the browser shows "React Client Manifest"
# errors, stop all dev servers, run `npm run dev:clean`, and avoid two `next dev` on the same port.

# Optional: block all OpenAI completions while keeping OPENAI_API_KEY set (UI-only dev; saves credits).
# OPENAI_DISABLED=true

# Optional: relax primary-extraction failover timeouts (defaults 3000 / 3500 ms). Use for local
# perf experiments when vision calls exceed the hard abort; remove before shipping tight budgets.
# VERIFY_EXTRACT_SOFT_TIMEOUT_MS=8000
# VERIFY_EXTRACT_HARD_TIMEOUT_MS=20000
